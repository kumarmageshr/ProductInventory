{
  "Auth": {
    "Authority": "https://login.microsoftonline.com/${AZURE_TENANT_ID}/v2.0",
    "Audience": "api://ecommerce-gateway"
  },
  "OpenTelemetry": {
    "Endpoint": "http://otel-collector:4317"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "https://ecommerce.example.com" ]
  },
  "ReverseProxy": {
    "Routes": {
      "product-route": {
        "ClusterId": "product-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "default",
        "Match": {
          "Path": "/api/products/{**remainder}"
        }
      },
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/inventory/{**remainder}"
        }
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "write-policy",
        "Match": {
          "Path": "/api/orders/{**remainder}"
        }
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "AuthorizationPolicy": "AdminPolicy",
        "Match": {
          "Path": "/api/payments/{**remainder}"
        }
      },
      "shipment-route": {
        "ClusterId": "shipment-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/shipments/{**remainder}"
        }
      }
    },
    "Clusters": {
      "product-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "HttpClient": {
          "MaxConnectionsPerServer": 100
        },
        "Destinations": {
          "primary": { "Address": "http://product-service:8080/" }
        }
      },
      "inventory-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "primary": { "Address": "http://inventory-service:8080/" }
        }
      },
      "order-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "primary": { "Address": "http://order-service:8080/" }
        }
      },
      "payment-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "primary": { "Address": "http://payment-service:8080/" }
        }
      },
      "shipment-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "primary": { "Address": "http://shipment-service:8080/" }
        }
      }
    }
  },
  "Serilog": {
    "MinimumLevel": { "Default": "Information" }
  },
  "AllowedHosts": "*"
}
